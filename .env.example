# ============================================================
#  Copy this file to .env and fill in your API keys
# ============================================================

# 1. Get from https://openrouter.ai  (free account)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 2. Get from https://apify.com  (free account - $5 monthly credit)
APIFY_API_TOKEN=your_apify_token_here

# 3. (Optional) Telegram bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ============================================================
#  Settings you can change
# ============================================================

# Starting fake money for paper trading (default $10,000)
STARTING_BALANCE=10000

# How often the agent checks markets (in minutes)
CHECK_INTERVAL_MINUTES=60